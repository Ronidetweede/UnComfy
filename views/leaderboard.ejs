<%- include("partials/header", { css: 'leaderboard.css' }) %>       
<img src="./assets/Logo/Logo.png" class="logoDesktop">
<header>
    <div class="header">
        <a href="/menu">
            <img src="assets/icons/left-arrow.png" alt="Pijl">
        </a>
        <div class="tabs">
            <button id="week-button" class="week-button active">Week</button>
        </div>
        <div class="top3">
            <div class="person second">
                <img class="secondplace" src="assets/icons/secondplace.png" alt="Second">
                        <img class="profile" src="<%= users[1]?.profilePicture ? '/uploads/' + users[1].profilePicture : 'assets/placeholders/Default_pfp.jpg' %>" alt="Profielfoto">
                        <p>
                            <%= users[1]?.displayName ?? "?" %>
                        </p>
                        <span>
                            <%= users[1]?.points ?? 0 %>
                        </span>
            </div>

                    <div class="person first">
                        <img class="crown" src="assets/icons/crown.png">
                        <img class="profile" src="<%= users[0]?.profilePicture ? '/uploads/' + users[0].profilePicture : 'assets/placeholders/Default_pfp.jpg' %>" alt="Profielfoto">
                        <p>
                            <%= users[0]?.displayName ?? "?" %>
                        </p>
                        <span>
                            <%= users[0]?.points ?? 0 %>
                        </span>
                    </div>

                    <div class="person third">
                        <img class="thirdplace" src="assets/icons/thirdplace.png">
                        <img class="profile" src="<%= users[2]?.profilePicture ? '/uploads/' + users[2].profilePicture : 'assets/placeholders/Default_pfp.jpg' %>" alt="Profielfoto">
                        <p>
                            <%= users[2]?.displayName ?? "?" %>
                        </p>
                        <span>
                            <%= users[2]?.points ?? 0 %>
                        </span>
                    </div>
                </div>
            </div>
            <div class="ranklist">
                <div class="item">
                    <span>4</span>
                    <img src="assets/placeholders/alex.png" alt="Alex">
                    <p>Alex Johnson</p>
                    <b>900</b>
                </div>

                <div class="item">
                    <span>5</span>
                    <img src="assets/placeholders/sarah.png" alt="Sarah">
                    <p>Sarah Mitchell</p>
                    <b>840</b>
                </div>

                <div class="item">
                    <span>6</span>
                    <img src="assets/placeholders/marcus.png" alt="Marcus">
                    <p>Marcus Chen</p>
                    <b>800</b>
                </div>

                <div class="item">
                    <span>7</span>
                    <img src="assets/placeholders/emma.png" alt="Emma">
                    <p>Emma Davis</p>
                    <b>740</b>
                </div>
            </div>
        </div>
    </header>
    </main>
<%- include("partials/footer") %>
