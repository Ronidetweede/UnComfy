<%- include("partials/header") %>
<link rel="stylesheet" href="/css/dailychallenges.css">
</head>

<body>
    <img src="../assets/Logo/Logo.png" class="logoDesktop">
    <header>
        <h3>«</h3>
        <h2>Daily Challenges</h2>
    </header>
    <main>
        <section class="filterChallenges">
            <form action="/dailychallenges" method="get">
                <input type="search" name="q" class="search-Challenge" placeholder="Zoek Challenges...">
            </form>
        </section>
        <section class="info-available-challenges">
            <div class="available-challenges">
                <h2>Beschikbaar</h2>
                <p><%= (availableChallenges.length) %></p>
            </div>
            <div class="completed-challenges">
                <h2>Gedaan</h2>
                <p><%= doneChallenges.length %></p>
            </div>
        </section>

        <section class="filter-Pills-Section">
            <div class="filter-Pills">
                        <a href="/dailychallenges?category=alle"><h3>Alle Challenges</h3></a>
                        <a href="/dailychallenges?category=sociaal"><h3>Sociaal</h3></a>
                        <a href="/getChallengeByIddailychallenges?category=fysiek"><h3>Fysiek</h3></a>
                        <a href="/dailychallenges?category=publiek"><h3>Publiek</h3></a>
                        <a href="/dailychallenges?category=mentaal"><h3>Mentaal</h3></a>
                </div>
        </section>

        <section class="dailyCards">
        
            <% for (let challenge of challenges) { %>
                <% if(!completedChallenges.includes(challenge.id)) { %>
            <div class="challengeCard">
                <div class="image-challenge">
                <div class="challenge-pills">
                    <div class="difficulity-pill">
                        <h3><%= challenge.difficulty %></h3>
                        <h3><%= challenge.category %></h3>
                </div>
                <div class="points-pill">
                    <h3><%= challenge.comfyPoints %> CP</h3>
                </div>
                </div>
            </div>
                <div class="info-Card">
                    <h2 class="title-challenge" title="<%= challenge.title %>"><%= challenge.title %></h2>
                    <div class="extra-InfoCard">
                        <p class="location-name"><img src="assets/icons/green-location.png" alt="Huis-icoon"> <%= challenge.location.address %></p>
                        <p class="people-joined"><img src="assets/icons/green-people.png" alt="Huis-icoon"> <%= challenge.joined_count %> gejoined</p>
                    </div>
                    <a href="/detailpage/<%= challenge.id %>"><button class="card-button">Meer Info</button></a>
                </div>
            </div>
            <% } %>
        <% } %>
        </section>
    </main>
<%- include("partials/footer") %>