<%- include("partials/header", { css: 'accountsetup.css' }) %>
<img src="./assets/Logo/Logo.png" class="logoDesktop">
<header>
  <a href="/profilepage" class="arrow"><</a>
  <h2 class="text-edit-profile">Bewerk Profiel</h2>
</header>
<main>
      <form action="/accountsetup" method="post" enctype="multipart/form-data">

    <section class="profile-picture">
      <div class="profile-circle">
        <img
              id="profile-preview"
          src="<%= profilePicture ? '/uploads/' + profilePicture : './assets/placeholders/Default_pfp.jpg' %>"
          alt="profile-picture"
          class="profile"
        />
        <button type="button" id="camera-btn">
          <img src="./assets/icons/camera-button.png" alt="camera-button" />
        </button>
      </div>

          <input type="file" id="photo-input" name="photo" accept="image/*" style="display:none">

          <h2><%= displayname %></h2>
          <p>Tik op de camera om de foto te wijzigen</p>
        </section>

  <section class="personal-info">
    <h2>Persoonlijke gegevens</h2>

          <div class="input-container">
            <label for="displayName">
              <img src="./assets/icons/green-profile.png" alt="green-person" />
              <p>Display Naam</p>
            </label>
            <input
              type="text"
              name="displayName"
              id="displayName"
              placeholder="<%= displayname %>"
              value="<%= displayname %>"
              required
            />
          </div>

          <div class="input-container">
            <label for="username">
              <img src="./assets/icons/green-at.png" alt="green-at" />
              <p>Gebruikersnaam</p>
            </label>
            <input
              type="text"
              name="username"
              id="username"
              placeholder="<%= username %>"
              value="<%= username %>"
              required
            />
          </div>

          <div class="input-container">
            <label for="email">
              <img src="./assets/icons/green-email.png" alt="green-email" />
              <p>Email</p>
            </label>
            <input
              type="email"
              name="email"
              id="email"
              placeholder="<%= email %>"
              value="<%= email %>"
              required
            />
          </div>
        </section>

        <button type="submit" class="save-button">
          <img src="./assets/icons/save-changes-icon.png" alt="save-changes-icon" />
          <p>Wijzigingen opslaan</p>
        </button>

      </form>
    </main>

    <script>
      const cameraBtn = document.getElementById("camera-btn");
      const photoInput = document.getElementById("photo-input");
      const profilePreview = document.getElementById("profile-preview");

      cameraBtn.addEventListener("click", () => {
        photoInput.click();
      });

      photoInput.addEventListener("change", () => {
        const file = photoInput.files[0];
        if (file) {
          profilePreview.src = URL.createObjectURL(file);
        }
      });
    </script>
