<!-- ANTWOORDEN MOETEN WORDEN BEWAARD PER GEBRUIKER OM EEN PLAN TE GEVEN -->


<%- include("partials/header") %>
<link rel="stylesheet" href="/css/generator-Part2.css">
</head>

<body>
    <main>

      
    <section class="assessment-Container">

    <div class="progress-Questions">
      <img src="/assets/icons/whiteBackButton.png" alt="whiteBackButton" class="backButton">
      <p class="question-Number">Vraag 1 van 6</p>
      <p class="percentage-Question">17%</p>
    </div>
      
  <div class="questions-Container">
    <h2 class="title-Question">Hoe goed kunt u omgaan met fysieke uitdagingen?</h2>
    <p class="desc-Question">Denk aan beweging, sport of buitenactiviteiten.</p>
<form action="/generator2" method="post">
    <ul class="difficulty-List">
      <li>
        <label class="option-Card">
          <input type="radio" name="difficulty" value= "beginner">
          <p>Beginner - I prefer gentle activities</p>
          <div class="custom-Radio"></div>
        </label>
      </li>
      <li>
        <label class="option-Card">
          <input type="radio" name="difficulty" value= "moderate">
          <p>Moderate - I'm somewhat active</p>
          <div class="custom-Radio"></div>
        </label>
      </li>
      <li>
        <label class="option-Card">
          <input type="radio" name="difficulty" value= "advanced">
          <p>Advanced - I love pushing my limits</p>
          <div class="custom-Radio"></div>
        </label>
      </li>
    </ul>
  </div>
  <button class="generator-Button">Start</button>
</form>
    </section>
</section>
    </main>
<script src="/js/generator.js"></script>
