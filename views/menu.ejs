<%- include("partials/header") %>
<link rel="stylesheet" href="/css/menu.css">
</head>
<body>
    <header class="mobile-header">
      <h1>un<br />(comfy)</h1>
    </header>

    <img src="./assets/Logo/Logo.png" class="logoDesktop">
    <header class="desktop-header">
        <h2>Welkom terug!</h2>
        <p>Tijd om uit je comfortzone te stappen</p>
    </header>

    <main>
      <% if (challenge) { %>
      <a href="/currentchallenge" class="todays-challenge-link">
      <section class="todays-challenge-section">
        <h2>Huidige Uitdaging</h2>
        <div class="todays-challenge">
          <p><%= challenge.title %></p>
        </div>
      </section>
      <% }else { %>
      <a href="/dailychallenges" class="todays-challenge-link">
      <section class="todays-challenge-section">
        <h2>Huidige Uitdaging</h2>
        <div class="todays-challenge">
          <p>Zoek Challenges</p>
        </div>
      </section>
      <% } %>
      </a>
      <section class="streak-container">
        <div class="streak-header">
          <div>
            <h2>Wekelijkse reeks</h2>
            <p>5 van de 7 dagen voltooid</p>
          </div>

          <div class="streak-icon">
            <img src="./assets/icons/streak-icon.png" alt="streak-icon" />
          </div>
        </div>

        <div class="days">
          <div class="day completed">M</div>
          <div class="day completed">D</div>
          <div class="day completed">W</div>
          <div class="day completed">D</div>
          <div class="day completed">V</div>
          <div class="day active">Z</div>
          <div class="day disabled">Z</div>
        </div>

        <div class="bonus">
          <span>Voltooi de week voor een bonus</span>
          <span>+100 CP</span>
        </div>
      </section>
      <a href="/leaderboard">
      <section class="leaderboard">
        <h2>Leaderbord</h2>
        <ul class="profile-images">
          <li><img src="./assets/placeholders/helena.png" alt="helena-profile-picture" width="200px" class="profile-1"></li>
          <li><img src="./assets/placeholders/emma.png" alt="profile1-picture" width="60px" class="profile-2"></li>
          <li><img src="./assets/placeholders/alex.png" alt="profile2-picture" width="60px" class="profile-3"></li>
        </ul>
      </section>
      </a>
      <section class="explore-challenges">
        <button><a href="/dailychallenges">Ontdek meer uitdagingen</a></button>
      </section>
    </main>
<%- include("partials/footer") %>
